
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SALF - Categorias</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --lar-salmao: #ea3d3d;
            --lar-escuro: #b92c2c;
            --lar-claro: #fceeee;
            --cinza-claro: #f8f9fa;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--cinza-claro);
            color: #212529;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }
        .sidebar {
            width: 240px;
            min-height: 100vh;
            background-color: var(--lar-escuro);
            color: white;
            position: fixed;
            padding: 1.5rem 1rem;
        }
        .sidebar a {
            display: block;
            color: #f8dada;
            text-decoration: none;
            margin: 0.75rem 0;
            font-weight: 500;
            transition: 0.3s;
        }
        .sidebar a:hover,
        .sidebar a.active {
            color: #fff;
            background-color: var(--lar-salmao);
            border-radius: 6px;
            padding: 0.5rem 1rem;
        }
        .main {
            margin-left: 240px;
            padding: 2rem;
            flex: 1;
        }
        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        }
        .btn-primary {
            background-color: var(--lar-salmao);
            border: none;
            border-radius: 8px;
            padding: 0.5rem 1rem;
        }
        .btn-primary:hover {
            background-color: #d93636;
        }
        .btn-success {
            background-color: #28a745;
            border: none;
        }
        .btn-success:hover {
            background-color: #218838;
        }
        .btn-secondary {
            background-color: #6c757d;
            border: none;
        }
        .btn-secondary:hover {
            background-color: #5a6268;
        }
        table thead {
            background-color: var(--lar-claro);
        }
        .form-area {
            background-color: #fff;
            padding: 1.5rem;
            border-radius: 12px;
            box-shadow: 0 1px 6px rgba(0,0,0,0.06);
        }
        footer {
            text-align: center;
            padding: 1rem;
            background-color: #f1f1f1;
            font-size: 0.9rem;
            color: #555;
            border-top: 1px solid #ddd;
            margin-left: 240px;
        }
    </style>
</head>
<body>

<div class="sidebar">
    <h4 class="text-center mb-4">SALF</h4>
    <a href="#">Dashboard</a>
    <a href="#">Funcionários</a>
    <a href="#">Produtos</a>
    <a href="#">Fornecedores</a>
    <a href="#" class="active">Categorias</a>
    <a href="#">Parametrização</a>
    <a href="#">Sair</a>
</div>

<div class="main">
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0">Gerenciamento de Categorias</h2>
            <button class="btn btn-primary" onclick="abrirFormulario()">Cadastrar Categoria</button>
        </div>

        <div class="card mb-4">
            <div class="card-body">
                <table class="table table-bordered table-hover">
                    <thead>
                    <tr>
                        <th>ID</th>
                        <th>Descrição</th>
                        <th class="text-end">Ações</th>
                    </tr>
                    </thead>
                    <tbody id="tabela-categorias">
                    <!-- Linhas dinâmicas -->
                    </tbody>
                </table>
            </div>
        </div>

        <div id="form-categoria" class="form-area" style="display:none">
            <h5 class="mb-3">Nova Categoria</h5>
            <form>
                <div class="mb-3">
                    <label for="descricao" class="form-label">Descrição</label>
                    <input type="text" class="form-control" id="descricao" required>
                </div>
                <button type="submit" class="btn btn-success">Salvar</button>
                <button type="button" class="btn btn-secondary" onclick="fecharFormulario()">Cancelar</button>
            </form>
        </div>
    </div>
</div>



<script>
    const apiUrl = 'http://localhost:8080/categorias';

    function carregarCategorias() {
        fetch(apiUrl)
            .then(res => res.json())
            .then(categorias => {
                const tbody = document.getElementById('tabela-categorias');
                tbody.innerHTML = '';
                categorias.forEach(cat => {
                    const linha = `<tr>
            <td>${cat.cat_cod}</td>
            <td>${cat.cat_desc}</td>
            <td class="text-end">
              <button class="btn btn-sm btn-outline-danger" onclick="excluirCategoria(${cat.cat_cod})">Excluir</button>
            </td>
          </tr>`;
                    tbody.innerHTML += linha;
                });
            });
    }

    function abrirFormulario() {
        document.getElementById('form-categoria').style.display = 'block';
    }

    function fecharFormulario() {
        document.getElementById('form-categoria').style.display = 'none';
    }

    document.querySelector('#form-categoria form').addEventListener('submit', function(e) {
        e.preventDefault();
        const cat_desc = document.getElementById('descricao').value;

        fetch(apiUrl, {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({cat_desc})
        })
            .then(() => {
                fecharFormulario();
                carregarCategorias();
                document.getElementById('form-categoria').querySelector('form').reset();
            });
    });

    function excluirCategoria(id) {
        if (confirm('Tem certeza que deseja excluir esta categoria?')) {
            fetch(`${apiUrl}/${id}`, { method: 'DELETE' })
                .then(() => carregarCategorias());
        }
    }

    carregarCategorias();
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
